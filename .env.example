# ─────────────────────────────────────────
# AWS
# ─────────────────────────────────────────

# Get these values from Terraform outputs after running 'terraform apply'
# Run: terraform output -raw aws_access_key_id
# Run: terraform output -raw aws_secret_access_key
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=sa-east-1
AWS_S3_BUCKET_NAME=dev-youvisa-files-3f8c2a

# Textract is not available in sa-east-1, use us-east-1
AWS_TEXTRACT_REGION=us-east-1

# ─────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────

# Obtain token from @BotFather on Telegram
# Format: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz123456789
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─────────────────────────────────────────
# MongoDB Atlas
# ─────────────────────────────────────────

# Shared across all services
MONGODB_URI=mongodb+srv://youvisa:<password>@cluster0.pncdzcg.mongodb.net/?appName=Cluster0
MONGODB_DATABASE=dev

# ─────────────────────────────────────────
# Applications

# ─────────────────────────────────────────
# app/api
# ─────────────────────────────────────────

API_NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=5555
API_KEY=fiap-iatron
API_IS_DEBUG=true

# API URL for n8n workflows
# Local development: http://localhost:5555
# Production: use LAMBDA_FUNCTION_URL
API_URL=http://host.docker.internal:5555

# Lambda Function URL (generated by Terraform)
LAMBDA_FUNCTION_URL=

# ─────────────────────────────────────────
# n8n
# ─────────────────────────────────────────

# Webhook URL
# For local development, use localhost
# For production, use your public domain with HTTPS
N8N_WEBHOOK_URL=http://localhost:5678/

# n8n AWS EC2 Configuration
# SSH Key name (must exist in AWS EC2 Key Pairs in sa-east-1)
# Create with: aws ec2 create-key-pair --key-name youvisa-n8n-key --region sa-east-1 --query 'KeyMaterial' --output text > ~/.ssh/youvisa-n8n-key.pem
N8N_SSH_KEY_NAME=youvisa-n8n-key

# n8n Basic Auth
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_this_password

# n8n Status Change Webhook
N8N_STATUS_WEBHOOK_URL=http://localhost:5678/webhook/status-change

# ─────────────────────────────────────────
# app/validation
# ─────────────────────────────────────────

LAMBDA_VALIDATION_FUNCTION_URL=

# ─────────────────────────────────────────
# app/nlp
# ─────────────────────────────────────────

LAMBDA_NLP_FUNCTION_URL=