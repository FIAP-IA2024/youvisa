# ─────────────────────────────────────────
# YOUVISA — Local development env
# ─────────────────────────────────────────
# Sprint 4 onwards everything runs locally via docker compose.
# AWS variables are deprecated and only relevant if you re-enable
# the (paused) Terraform deploy paths.

# ─────────────────────────────────────────
# MongoDB (local container)
# ─────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017
MONGODB_DATABASE=youvisa

# ─────────────────────────────────────────
# MinIO (local S3-compatible storage)
# ─────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=youvisa-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ─────────────────────────────────────────
# Telegram bot
# ─────────────────────────────────────────
# Obtain token from @BotFather on Telegram.
# Sprint 4 reuses @youvisa_test_assistant_bot.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─────────────────────────────────────────
# API (Fastify backend)
# ─────────────────────────────────────────
API_NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=5555
API_KEY=fiap-iatron
API_IS_DEBUG=true
# URL the agent and frontend use to reach the API
API_URL=http://api:5555

# ─────────────────────────────────────────
# Agent service (Phase 3+ of Sprint 4)
# ─────────────────────────────────────────
# Generated by `claude setup-token` from inside the agent container.
# See docs/DEV_SETUP.md.
CLAUDE_CODE_OAUTH_TOKEN=

# Default Claude model for all agent steps; can be overridden per agent.
CLAUDE_MODEL=claude-haiku-4-5

# JWT secret for portal tokens (generate with: openssl rand -hex 32)
PORTAL_SECRET=replace_me_with_openssl_rand_hex_32
PORTAL_TTL_HOURS=24
PORTAL_BASE_URL=http://localhost:3000

# Agent service HTTP port
AGENT_PORT=7777

# ─────────────────────────────────────────
# Frontend (Next.js, container :3000 mapped to host :3010)
# ─────────────────────────────────────────
# URL the frontend uses to reach the API (browser side)
NEXT_PUBLIC_API_URL=http://localhost:5555
# URL the frontend uses to reach the agent (browser side, for visa-guidance fetch)
NEXT_PUBLIC_AGENT_URL=http://localhost:7777
# In-network agent URL (server-side RSC fetching)
AGENT_URL=http://agent:7777
DASHBOARD_PASSWORD=Teste1234
DASHBOARD_SESSION_SECRET=replace_me_with_openssl_rand_hex_32
