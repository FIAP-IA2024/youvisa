{
  "name": "@youvisa/agent",
  "version": "0.0.1",
  "private": true,
  "description": "YOUVISA agent service: multi-agent pipeline + Telegram webhook + document classification (Sprint 4)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "node --max-old-space-size=6144 ./node_modules/typescript/bin/tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.110",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.7.0",
    "hono": "^4.12.0",
    "jose": "^5.9.0",
    "mongoose": "^8.9.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
