      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2450, 100]
    },
    {
      "parameters": {
        "url": "=__API_URL__/processes/telegram/{{ $node['Telegram Trigger'].json.message.from.id }}",
        "method": "GET",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "__API_KEY__"
            }
          ]
        },
        "options": {}
      },
      "name": "Get User Processes",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2650, 100]
    },
    {
      "parameters": {
        "jsCode": "const processes = $json.data || [];\nconst fileId = $node['Save File Record'].json.data._id;\n\n// Find an open process (not in final state)\nconst openProcess = processes.find(p => \n  ['recebido', 'em_analise', 'pendente_documentos'].includes(p.status)\n);\n\nif (openProcess) {\n  return [{ json: { hasProcess: true, processId: openProcess._id, fileId } }];\n} else {\n  return [{ json: { hasProcess: false, fileId, userId: $node['Upsert User'].json.data._id } }];\n}"
      },
      "name": "Check Open Process",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2850, 100]
    },
