    {
      "parameters": {
        "resource": "file",
        "operation": "get",
        "fileId": "={{ $node['Telegram Trigger'].json.message.document ? $node['Telegram Trigger'].json.message.document.file_id : $node['Telegram Trigger'].json.message.photo[$node['Telegram Trigger'].json.message.photo.length - 1].file_id }}",
        "download": true
      },
      "name": "Get File from Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1050, 250],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Extract binary data and convert to base64 for validation\nconst binaryData = $input.item.binary.data;\n\nif (!binaryData) {\n  throw new Error('No binary data found');\n}\n\n// The binary data from Telegram node contains base64 in the 'data' property\nconst base64Data = binaryData.data;\n\n// Store full binary data info in JSON so it can be reconstructed later\n// (binary data is lost when passing through HTTP Request nodes)\nreturn [{\n  json: {\n    imageBase64: base64Data,\n    mimeType: binaryData.mimeType,\n    fileName: binaryData.fileName,\n    fileExtension: binaryData.fileExtension,\n    // Store complete binary info for reconstruction\n    binaryInfo: {\n      data: binaryData.data,\n      mimeType: binaryData.mimeType,\n      fileName: binaryData.fileName,\n      fileExtension: binaryData.fileExtension\n    }\n  },\n  binary: {\n    data: binaryData\n  }\n}];"
      },
      "name": "Extract Base64",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1250, 250]
    },
    {
      "parameters": {
        "url": "__VALIDATION_URL__",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "x-api-key",
              "value": "__API_KEY__"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ image: $json.imageBase64 }) }}",
        "options": {}
      },
      "name": "Validate Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1450, 250]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.valid }}",
              "value2": true
            }
          ]
        }
      },
      "name": "Check Validation",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1650, 250]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $node['Telegram Trigger'].json.message.chat.id }}",
        "text": "={{ 'A imagem do documento não passou na validação: ' + $node['Validate Image'].json.reason }}"
      },
      "name": "Send Validation Error",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1850, 400],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot API"
        }
      }
    },
    {
      "parameters": {
        "url": "=__API_URL__/messages",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "__API_KEY__"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  conversation_id: $node['Upsert Conversation'].json.data._id,\n  message_id: 'bot_validation_' + Date.now(),\n  user_id: $node['Upsert Conversation'].json.data.user_id,\n  text: 'A imagem do documento não passou na validação: ' + $node['Validate Image'].json.reason,\n  message_type: 'text',\n  direction: 'outgoing',\n  timestamp: new Date().toISOString(),\n  metadata: {\n    type: 'validation_error',\n    reason: $node['Validate Image'].json.reason\n  }\n}) }}",
        "options": {}
      },
      "name": "Save Bot Response Validation",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2050, 400]
    },
    {
      "parameters": {
        "jsCode": "// Reconstruct binary data from the JSON saved in Extract Base64\n// (binary data is lost when passing through HTTP Request and IF nodes)\nconst binaryInfo = $node['Extract Base64'].json.binaryInfo;\nconst message = $node['Telegram Trigger'].json.message;\nconst conversation = $node['Upsert Conversation'].json.data;\nconst now = new Date();\n\nlet fileInfo;\nif (message.document) {\n  fileInfo = {\n    file_id: message.document.file_id,\n    file_name: message.document.file_name,\n    file_size: message.document.file_size,\n    mime_type: message.document.mime_type,\n    message_type: 'document'\n  };\n} else if (message.photo) {\n  const photo = message.photo[message.photo.length - 1];\n  fileInfo = {\n    file_id: photo.file_id,\n    file_name: `photo_${photo.file_unique_id}.jpg`,\n    file_size: photo.file_size,\n    mime_type: 'image/jpeg',\n    message_type: 'photo'\n  };\n}\n\nconst timestamp = now.getTime();\nconst fileName = `${fileInfo.file_id}_${timestamp}_${fileInfo.file_name}`;\nconst s3Key = fileName;\n\nreturn [{\n  json: {\n    s3Key: s3Key,\n    fileName: fileInfo.file_name,\n    fileSize: fileInfo.file_size,\n    mimeType: fileInfo.mime_type,\n    messageType: fileInfo.message_type,\n    fileId: fileInfo.file_id,\n    messageId: String(message.message_id),\n    conversationId: conversation._id,\n    userId: conversation.user_id,\n    timestamp: new Date(message.date * 1000).toISOString()\n  },\n  binary: {\n    data: {\n      data: binaryInfo.data,\n      mimeType: binaryInfo.mimeType,\n      fileName: binaryInfo.fileName,\n      fileExtension: binaryInfo.fileExtension\n    }\n  }\n}];"
      },
      "name": "Prepare S3 Upload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1850, 100]
    },
    {
      "parameters": {
        "operation": "upload",
        "bucketName": "__S3_BUCKET__",
        "fileName": "={{ $json.s3Key }}",
        "binaryData": true,
        "binaryPropertyName": "data",
        "region": "sa-east-1",
        "additionalFields": {
          "contentType": "={{ $json.mimeType }}"
        }
      },
      "name": "Upload to S3",
      "type": "n8n-nodes-base.awsS3",
      "typeVersion": 1,
      "position": [2050, 100],
      "credentials": {
        "aws": {
          "id": "2",
